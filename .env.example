# Configurações de Sintonização Sirius-Arkhos
# Renomeie este arquivo para .env e insira suas chaves de poder

# Chave Mestra do Google AI Studio (Gemini)
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=

# Portas de Expansão (Opcional)
GROQ_API_KEY=
NVIDIA_API_KEY=

# Configurações de Ambiente
NODE_ENV=development
PORT=3000

# Integração Telegram (Opcional)
TELEGRAM_TOKEN=
WEBHOOK_URL=
